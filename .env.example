# ZipList Environment Variables
# Copy this file to .env and fill in your values

# Server-side Gemini API Key (required)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# API hardening
API_RATE_LIMIT=30
API_RATE_WINDOW_MS=60000
MAX_UPLOAD_BYTES=15728640
# Comma-separated allowlist for deployed origins. Leave blank to allow any origin.
ALLOWED_ORIGINS=

# PostHog Analytics (optional)
# Get your API key from: https://posthog.com
# VITE_POSTHOG_KEY=your_posthog_key_here
# VITE_POSTHOG_HOST=https://app.posthog.com

# Whisper Offline Transcription (optional)
# Privacy mode forces offline-only transcription (no API calls)
# When disabled, uses Gemini API while Whisper loads in background
# VITE_PRIVACY_MODE=false
# VITE_WHISPER_MODEL=tiny

# Optional: Development settings
# VITE_DEBUG=false
# VITE_API_TIMEOUT=30000

# Optional: PartyKit live collaboration
# Leave unset for solo/demo deployments. The UI will hide live-collab controls.
# VITE_PARTYKIT_HOST=ziplist.your-actual-host.partykit.dev
# Server-side proxy can also read this private host value.
# PARTYKIT_HOST=ziplist.your-actual-host.partykit.dev
# Set the same secret in PartyKit production env to protect room creation.
# PARTYKIT_CREATE_SECRET=replace_with_a_long_random_secret
# For real-device local testing, the app can infer LAN PartyKit in dev.
# You can also set VITE_PARTYKIT_HOST=192.168.0.148:1999 explicitly.

# Optional: Contributor unlocks
# One-time $9 AUD checkout uses Square. Manual codes work without Square.
# CONTRIBUTOR_UNLOCK_CODES=ZL-DEMO-CODE
# CONTRIBUTOR_LICENSE_SECRET=replace_with_at_least_16_random_chars
# PUBLIC_FORCE_CONTRIBUTOR_MODE=false
# ZIPLIST_STORAGE_ADAPTER=filesystem
# ZIPLIST_DATA_DIR=./data

# Optional: Square checkout for Contributor Pass
# PUBLIC_APP_URL=https://ziplist.app
# SQUARE_ENVIRONMENT=sandbox
# SQUARE_API_VERSION=2026-01-22
# SQUARE_ACCESS_TOKEN=your_square_access_token
# SQUARE_LOCATION_ID=your_square_location_id
# SQUARE_WEBHOOK_SIGNATURE_KEY=your_square_webhook_signature_key
# SQUARE_WEBHOOK_NOTIFICATION_URL=https://ziplist.app/api/square/webhook
